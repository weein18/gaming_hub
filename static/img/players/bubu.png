      <div class="modal-footer community-modal-footer">
        <button type="button" class="btn btn-secondary community-btn-secondary" data-dismiss="modal">
          <i class="fas fa-times"></i>
          Cancel
        </button>
        <button type="submit" class="btn btn-primary community-btn-primary" form="sendProfileUpdate">
          <i class="fas fa-paper-plane"></i>
          Submit Update
        </button>
      </div>
    </div>
  </div>
</div>

